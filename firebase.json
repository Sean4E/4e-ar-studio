{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "storage.rules",
      "config.template.js",
      "ARCHITECTURE.md",
      "README.md",
      "Credentials/**",
      "GLB_Files/**",
      "Images/**",
      "_LOGOS/**",
      "_BACKUPS/**",
      "_XREXTRAS/**",
      "assets/**",
      "studio/diagnose/**",
      "builder.html",
      "devstudio.html",
      ".git/**",
      ".github/**",
      "node_modules/**",
      "docs/aframe-hider-test.html",
      "docs/hider-test.html",
      "docs/fullscreen-test.html",
      "docs/prefab-basescale-test.html",
      "docs/rigged-traveller-test.html",
      "docs/traveller-anim-test.html",
      "docs/journey-runtime-test.html",
      "docs/architecture.html"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "**/*.glb",
        "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
      },
      {
        "source": "**/*.mind",
        "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
      },
      {
        "source": "**/*.usdz",
        "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
      }
    ]
  }
}
